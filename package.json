{
  "name": "@takazudo/zudo-design-token-lint",
  "version": "0.1.0",
  "description": "Lint Tailwind CSS class names against design system tokens. Enforce semantic spacing and color tokens instead of raw numeric utilities.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "design-token-lint": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "// ── Lint package ────────────────────────────────": "",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "prepublishOnly": "pnpm run build && pnpm run test",
    "// ── Doc site (workspace shortcuts) ──────────────": "",
    "dev:doc": "pnpm --filter @takazudo/zudo-design-token-lint-doc dev",
    "build:doc": "pnpm --filter @takazudo/zudo-design-token-lint-doc build",
    "preview:doc": "pnpm --filter @takazudo/zudo-design-token-lint-doc preview",
    "check:doc": "pnpm --filter @takazudo/zudo-design-token-lint-doc check"
  },
  "keywords": [
    "design-system",
    "lint",
    "tailwind",
    "css",
    "design-tokens"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Takazudo/zudo-design-token-lint.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "glob": "^11.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.3"
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70"
}
